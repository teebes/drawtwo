APPLE_SIGN_IN_WEB_CLIENT_ID=com.example.drawtwo.dev.web
APPLE_SIGN_IN_IOS_CLIENT_ID=com.example.drawtwo.dev
VITE_APPLE_REDIRECT_URI=https://drawtwo.com/auth/callback/apple
